# Production Environment Variables for Vercel
# Copy these to Vercel Dashboard → Settings → Environment Variables
#
# NEXT_PUBLIC_* = exposed to browser bundle
# Non-prefixed    = server-only (Route Handlers, middleware)

# --- Client-side ---

NEXT_PUBLIC_SITE_URL=https://dentalstory.ua
NEXT_PUBLIC_ENVIRONMENT=production
NEXT_PUBLIC_API_URL=https://api.dentalstory.com.ua

# Contact Information - Lviv Clinic
NEXT_PUBLIC_PHONE_NUMBER=+380682323838
NEXT_PUBLIC_EMERGENCY_PHONE=+380682323838
NEXT_PUBLIC_EMAIL=info@dentalstory.ua

# Social Media
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/dentalstoryylviv/
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/dentalstory_lviv/
NEXT_PUBLIC_TELEGRAM_URL=https://t.me/dentalstorylviv

# Google Services
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_production_google_maps_api_key
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Feature Flags
NEXT_PUBLIC_ENABLE_CLINICARDS_INTEGRATION=true
NEXT_PUBLIC_ENABLE_PATIENT_PORTAL=true
NEXT_PUBLIC_ENABLE_ONLINE_BOOKING=true

# --- Server-only ---

SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
CLINICARDS_API_KEY=your_production_clinicards_api_key
CLINICARDS_API_URL=https://api.cliniccards.com/v1
MONITORING_ENDPOINT=https://your-monitoring-service.com/api
API_TIMEOUT=10000
CACHE_TTL=300000
PRICE_LIST_REFRESH_INTERVAL=3600000
