# Production Environment Variables for Vercel
# Copy this file to Vercel Dashboard → Settings → Environment Variables

# Site Configuration
VITE_SITE_URL=https://dentalstory.ua
VITE_ENVIRONMENT=production

# Contact Information - Lviv Clinic
VITE_PHONE_NUMBER=+380682323838
VITE_EMERGENCY_PHONE=+380682323838
VITE_EMAIL=info@dentalstory.ua

# Social Media
VITE_FACEBOOK_URL=https://www.facebook.com/dentalstoryylviv/
VITE_INSTAGRAM_URL=https://www.instagram.com/dentalstory_lviv/
VITE_TELEGRAM_URL=https://t.me/dentalstorylviv

# Google Services
VITE_GOOGLE_MAPS_API_KEY=your_production_google_maps_api_key
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Error Tracking
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# CliniCards API Configuration
VITE_CLINICARDS_API_KEY=your_production_clinicards_api_key
VITE_CLINICARDS_API_URL=https://api.cliniccards.com/v1

# API Configuration
VITE_API_URL=https://api.dentalstory.com.ua
VITE_API_TIMEOUT=10000
VITE_CACHE_TTL=300000
VITE_PRICE_LIST_REFRESH_INTERVAL=3600000

# Feature Flags
VITE_ENABLE_CLINICARDS_INTEGRATION=true
VITE_ENABLE_PATIENT_PORTAL=true
VITE_ENABLE_ONLINE_BOOKING=true

# Monitoring (Optional)
VITE_MONITORING_ENDPOINT=https://your-monitoring-service.com/api
