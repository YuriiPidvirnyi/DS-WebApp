# =============================================================================
# NEXT_PUBLIC_* — exposed to the browser
# Non-prefixed — SERVER-ONLY (Route Handlers, middleware)
# =============================================================================

# --- Client-side ---

# Site
NEXT_PUBLIC_SITE_URL=https://dentalstory.com.ua

# Google Analytics (optional)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Supabase (required for auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Server-side admin key (required only for live email-link E2E helper)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Cloudflare Turnstile CAPTCHA (optional — skipped if missing)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key

# Environment label (used by Sentry)
NEXT_PUBLIC_ENVIRONMENT=production

# --- Server-only ---

# Sentry error tracking (optional — skipped if missing)
SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# Redis cache (optional — skipped if missing)
# Supports both Vercel KV aliases and Upstash direct env vars:
#   KV_REST_API_URL / KV_REST_API_TOKEN   (auto-set by Vercel KV integration)
#   UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN   (manual Upstash setup)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# Cloudflare Turnstile secret (required if site key is set)
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# CliniCards API
CLINICARDS_API_KEY=your_clinicards_api_key
CLINICARDS_API_URL=https://api.cliniccards.com/v1

# Resend email (optional — notification emails skipped if missing)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=DentalStory <noreply@dentalstory.com.ua>

# Admin notifications
ADMIN_NOTIFICATION_EMAIL=admin@dentalstory.com.ua

# Vercel Cron secret (secures /api/cron/* endpoints)
CRON_SECRET=your_cron_secret
