# =============================================================================
# NEXT_PUBLIC_* — exposed to the browser
# Non-prefixed — SERVER-ONLY (Route Handlers, middleware)
# =============================================================================

# --- Client-side ---

# Site
NEXT_PUBLIC_SITE_URL=https://dentalstory.ua

# Google Analytics (optional)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Google Business Profile Place ID (optional — /r/google falls back to the
# Maps share link until set). Get it from the Place ID Finder:
# https://developers.google.com/maps/documentation/places/web-service/place-id
NEXT_PUBLIC_GOOGLE_PLACE_ID=ChIJXXXXXXXXXXXXXXXXXXXX

# Supabase (required for auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Server-side admin key (required only for live email-link E2E helper)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Cloudflare Turnstile CAPTCHA (optional — skipped if missing)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key

# Environment label (used by Sentry)
NEXT_PUBLIC_ENVIRONMENT=production

# --- Server-only ---

# Sentry error tracking (optional — skipped if missing)
SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# Redis cache (optional — skipped if missing)
# Supports both Vercel KV aliases and Upstash direct env vars:
#   KV_REST_API_URL / KV_REST_API_TOKEN   (auto-set by Vercel KV integration)
#   UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN   (manual Upstash setup)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# Cloudflare Turnstile secret (required if site key is set)
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# CliniCards API key for appointment slot availability
CLINICARDS_API_KEY=your_clinicards_api_key
CLINICARDS_API_URL=https://api.cliniccards.com/v1

# Resend email (optional — notification emails skipped if missing)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=DentalStory <noreply@dentalstory.ua>

# Admin alert email — receives new booking notifications
ADMIN_NOTIFICATION_EMAIL=admin@dentalstory.ua

# Admin bearer for /api/payments/* routes — REQUIRED in production (routes return 500 if unset).
# NOTE: no longer used by any scheduled job. Scheduled work moved to Supabase pg_cron
# (see supabase/migrations/20260718_cron_*.sql). The notifications drain runs as the
# `process-notifications` Supabase edge function; set its secrets in the Supabase dashboard
# (NOT here): NOTIFY_FN_SECRET, RESEND_API_KEY, RESEND_FROM_EMAIL, ADMIN_NOTIFICATION_EMAIL, SITE_URL.
# NOTIFY_FN_SECRET must equal the Supabase Vault secret `process_notifications_invoke_secret`.
CRON_SECRET=your_cron_secret
