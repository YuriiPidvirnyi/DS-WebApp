# =============================================================================
# NEXT_PUBLIC_* vars are exposed to the browser bundle
# Non-prefixed vars are SERVER-ONLY (Route Handlers, middleware, etc.)
# =============================================================================

# --- Client-side (browser) ---

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://dentalstory.com.ua
NEXT_PUBLIC_ENVIRONMENT=development

# API base URL
# Development: point to local backend if running separately
# Production: omit (defaults to /api — Next.js Route Handlers)
# NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Contact Information - Lviv Clinic
NEXT_PUBLIC_PHONE_NUMBER=+380682323838
NEXT_PUBLIC_EMERGENCY_PHONE=+380682323838
NEXT_PUBLIC_EMAIL=info@dentalstory.ua

# Social Media
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/dentalstoryylviv/
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/dentalstory_lviv/
NEXT_PUBLIC_TELEGRAM_URL=https://t.me/dentalstory

# Google Services
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Feature Flags
NEXT_PUBLIC_ENABLE_CLINICARDS_INTEGRATION=true
NEXT_PUBLIC_ENABLE_PATIENT_PORTAL=true
NEXT_PUBLIC_ENABLE_ONLINE_BOOKING=true

# --- Server-only (NOT exposed to browser) ---

# Error Tracking — kept server-only for security
SENTRY_DSN=your_sentry_dsn_here

# CliniCards API — server-only (proxied via Route Handlers)
CLINICARDS_API_KEY=your_clinicards_api_key_here
CLINICARDS_API_URL=https://api.cliniccards.com/v1

# Monitoring
MONITORING_ENDPOINT=https://your-monitoring-service.com/api

# Timeouts & cache (used server-side)
API_TIMEOUT=10000
CACHE_TTL=300000
PRICE_LIST_REFRESH_INTERVAL=3600000
