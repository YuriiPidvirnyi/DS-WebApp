# API Configuration
VITE_API_URL=http://localhost:3001/api

# Contact Information - Lviv Clinic
VITE_PHONE_NUMBER=+380682323838
VITE_EMERGENCY_PHONE=+380682323838
VITE_EMAIL=info@dentalstory.ua

# Social Media
VITE_FACEBOOK_URL=https://www.facebook.com/dentalstoryylviv/
VITE_INSTAGRAM_URL=https://www.instagram.com/dentalstory_lviv/
VITE_TELEGRAM_URL=https://t.me/dentalstory

# Google Services
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Error Tracking (Optional)
VITE_SENTRY_DSN=your_sentry_dsn_here

# Site Configuration
VITE_SITE_URL=https://dentalstory.com.ua
VITE_ENVIRONMENT=development

# CliniCards API Configuration
# Get your API key from: https://app.cliniccards.com/settings/api
VITE_CLINICARDS_API_KEY=your_clinicards_api_key_here
VITE_CLINICARDS_API_URL=https://api.cliniccards.com/v1

# Monitoring Configuration (optional)
VITE_MONITORING_ENDPOINT=https://your-monitoring-service.com/api

# Feature Flags
VITE_ENABLE_CLINICARDS_INTEGRATION=true
VITE_ENABLE_PATIENT_PORTAL=true
VITE_ENABLE_ONLINE_BOOKING=true

# Cloudflare Turnstile (Optional)
VITE_TURNSTILE_SITE_KEY=

# Build Metadata (set by CI)
VITE_APP_VERSION=
VITE_BUILD_ID=

# API Configuration
VITE_API_TIMEOUT=10000
VITE_CACHE_TTL=300000
VITE_PRICE_LIST_REFRESH_INTERVAL=3600000
