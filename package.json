{
  "name": "dental-story-webapp",
  "version": "1.0.0",
  "description": "Modern webapp for Dental Story dental clinic",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:analyze": "tsc && vite build --mode analyze",
    "preview": "vite preview",
    "preview:e2e": "node scripts/preview-server.js",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 100",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "a11y:audit": "npm run build && node scripts/a11y-audit.mjs",
    "a11y:install": "npx playwright install chromium",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:ci": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test tests/visual",
    "test:visual:update": "playwright test tests/visual --update-snapshots",
    "perf:check": "node scripts/check-performance-budgets.js",
    "perf:build": "npm run build && npm run perf:check",
    "lighthouse": "lhci autorun",
    "lighthouse:mobile": "lhci autorun --collect.settings.preset=mobile",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "benchmark": "node scripts/benchmark.js",
    "seo:sitemap": "node scripts/generate-sitemap.js",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@sentry/browser": "^10.23.0",
    "@sentry/integrations": "^7.114.0",
    "@sentry/react": "^10.20.0",
    "@sentry/replay": "^7.116.0",
    "@sentry/tracing": "^7.120.4",
    "@types/dompurify": "^3.0.5",
    "axios": "^1.12.2",
    "clsx": "^2.0.0",
    "dompurify": "^3.3.0",
    "hoist-non-react-statics": "^3.3.2",
    "i18next": "^25.6.1",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.65.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^16.2.4",
    "react-router-dom": "^7.9.4",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@chromatic-com/storybook": "^4.1.2",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.56.1",
    "@size-limit/preset-app": "^11.2.0",
    "@storybook/addon-a11y": "^10.0.1",
    "@storybook/addon-docs": "^10.0.1",
    "@storybook/addon-onboarding": "^10.0.1",
    "@storybook/addon-vitest": "^10.0.1",
    "@storybook/react-vite": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vitejs/plugin-react": "^4.1.1",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.16",
    "axe-core": "^4.11.0",
    "eslint": "^8.53.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "eslint-plugin-storybook": "^10.0.1",
    "express": "^5.1.0",
    "husky": "^9.1.7",
    "jsdom": "^27.0.1",
    "lint-staged": "^16.2.6",
    "playwright": "^1.56.1",
    "postcss": "^8.4.31",
    "prettier": "^3.1.0",
    "storybook": "^10.0.1",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vite": "^7.1.12",
    "vite-plugin-pwa": "^1.1.0",
    "vitest": "^3.2.4",
    "web-vitals": "^5.1.0"
  },
  "keywords": [
    "dental-clinic",
    "healthcare",
    "react",
    "typescript",
    "vite"
  ],
  "author": "Dental Story",
  "license": "MIT"
}
