{
  "name": "dental-story-webapp",
  "version": "3.1.0",
  "description": "Modern webapp for Dental Story dental clinic",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:kill": "npx --yes kill-port 3000",
    "dev:clear-turbo": "node ./scripts/clean-turbopack-cache.mjs",
    "dev:restart": "npm run dev:kill && npm run dev:clear-turbo && npm run dev",
    "build": "next build",
    "build:check": "npm run typecheck && npm run lint && npm run build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint src/ app/ --report-unused-disable-directives --max-warnings 100",
    "lint:fix": "eslint src/ app/ --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e:ui-smoke": "playwright test e2e/ui-form-controls.smoke.spec.ts --config=playwright.auth.config.ts",
    "test:e2e:auth": "playwright test e2e/auth-flows.spec.ts e2e/auth-confirm-flow.spec.ts --config=playwright.auth.config.ts",
    "test:e2e:auth:live": "playwright test e2e/auth-live.smoke.spec.ts --config=playwright.auth.live.config.ts",
    "test:e2e:auth:links:live": "playwright test e2e/auth-email-links.live.spec.ts --config=playwright.auth.links.live.config.ts",
    "a11y:install": "npx playwright install chromium",
    "a11y:audit": "node scripts/a11y-audit.mjs",
    "seed:preprod": "npx tsx scripts/seed/preprod/index.ts",
    "seed:preprod:wipe": "SEED_WIPE=1 npx tsx scripts/seed/preprod/index.ts",
    "seed:rbac": "node scripts/seed-rbac-test-users.mjs",
    "link-env": "node scripts/link-env.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/react": "^4.0.34",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@hookform/resolvers": "^5.4.0",
    "@sentry/nextjs": "^10.65.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.2",
    "@types/dompurify": "^3.2.0",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/edge-config": "^1.4.3",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^7.0.4",
    "clsx": "^2.0.0",
    "dompurify": "^3.4.12",
    "i18next": "^26.3.6",
    "lucide-react": "^1.25.0",
    "next": "^16.2.10",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.82.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^17.0.9",
    "react-is": "^19.2.7",
    "recharts": "^3.9.2",
    "require-in-the-middle": "^8.0.1",
    "resend": "^6.17.2",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.5.0",
    "@next/bundle-analyzer": "^16.2.10",
    "@next/eslint-plugin-next": "^16.2.10",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.0",
    "postcss": "^8.5.20",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10",
    "web-vitals": "^5.3.0"
  },
  "keywords": [
    "dental-clinic",
    "healthcare",
    "react",
    "typescript",
    "nextjs"
  ],
  "author": "Dental Story",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=9.0.0"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.5",
    "lodash": ">=4.17.24",
    "postcss": "$postcss"
  }
}
