{
  "name": "dental-story-webapp",
  "version": "2.0.0",
  "description": "Modern webapp for Dental Story dental clinic",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/ app/ --report-unused-disable-directives --max-warnings 100",
    "lint:fix": "eslint src/ app/ --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "a11y:audit": "npm run build && node scripts/a11y-audit.mjs",
    "a11y:install": "npx playwright install chromium",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:ci": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test tests/visual",
    "test:visual:update": "playwright test tests/visual --update-snapshots",
    "perf:check": "node scripts/check-performance-budgets.js",
    "perf:build": "npm run build && npm run perf:check",
    "lighthouse": "lhci autorun",
    "lighthouse:mobile": "lhci autorun --collect.settings.preset=mobile",
    "benchmark": "node scripts/benchmark.js",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@sentry/nextjs": "^10.39.0",
    "@types/dompurify": "^3.0.5",
    "@vercel/analytics": "^1.6.1",
    "clsx": "^2.0.0",
    "dompurify": "^3.3.0",
    "i18next": "^25.6.1",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "lucide-react": "^0.294.0",
    "next": "^16.1.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.65.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^16.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@chromatic-com/storybook": "^4.1.2",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@next/eslint-plugin-next": "^16.1.6",
    "@playwright/test": "^1.56.1",
    "@size-limit/preset-app": "^12.0.0",
    "@storybook/addon-a11y": "^10.2.10",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/addon-onboarding": "^10.2.10",
    "@storybook/addon-vitest": "^10.2.10",
    "@storybook/nextjs": "^10.2.13",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.16",
    "axe-core": "^4.11.0",
    "eslint": "^10.0.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.1",
    "eslint-plugin-storybook": "^10.2.10",
    "express": "^5.1.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^27.0.1",
    "lint-staged": "^16.2.6",
    "playwright": "^1.56.1",
    "postcss": "^8.4.31",
    "prettier": "^3.8.1",
    "storybook": "^10.2.13",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18",
    "web-vitals": "^5.1.0"
  },
  "keywords": [
    "dental-clinic",
    "healthcare",
    "react",
    "typescript",
    "nextjs"
  ],
  "author": "Dental Story",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
