{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/cron/notifications",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/low-stock-alerts",
      "schedule": "0 8 * * 1-5"
    }
  ]
}
